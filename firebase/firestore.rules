rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /gomokuRooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && validRoom(request.resource.data, roomId)
        && request.resource.data.players.black.uid == request.auth.uid
        && request.resource.data.players.white == null;
      allow update: if signedIn()
        && validRoom(request.resource.data, roomId)
        && request.resource.data.roomCode == resource.data.roomCode
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          validJoin()
          || validPlayerUpdate()
        );
      allow delete: if false;
    }
  }

  function signedIn() {
    return request.auth != null;
  }

  function allowedRoomKeys() {
    return [
      'roomCode', 'board', 'currentPlayer', 'status', 'winner',
      'players', 'moveHistory', 'lastMove', 'createdAt', 'updatedAt'
    ];
  }

  function validRoom(data, id) {
    return data.keys().hasOnly(allowedRoomKeys())
      && data.roomCode is string
      && data.roomCode == id
      && data.roomCode.size() >= 4
      && data.roomCode.size() <= 8
      && data.board is list
      && data.board.size() == 225
      && validColor(data.currentPlayer)
      && validStatus(data.status)
      && validWinner(data.winner)
      && data.players is map
      && data.players.keys().hasOnly(['black', 'white'])
      && validPlayer(data.players.black)
      && (data.players.white == null || validPlayer(data.players.white))
      && data.moveHistory is list
      && data.moveHistory.size() <= 225
      && (data.lastMove == null || data.lastMove is map);
  }

  function validColor(color) {
    return color == 1 || color == 2;
  }

  function validWinner(winner) {
    return winner == 0 || winner == 1 || winner == 2;
  }

  function validStatus(status) {
    return status == 'playing' || status == 'ended';
  }

  function validPlayer(player) {
    return player is map
      && player.keys().hasOnly(['uid', 'name'])
      && player.uid is string
      && player.uid.size() > 0
      && player.uid.size() <= 128
      && player.name is string
      && player.name.size() > 0
      && player.name.size() <= 18;
  }

  function isBlack(data) {
    return data.players.black.uid == request.auth.uid;
  }

  function isWhite(data) {
    return data.players.white != null && data.players.white.uid == request.auth.uid;
  }

  function isPlayer(data) {
    return isBlack(data) || isWhite(data);
  }

  function validJoin() {
    return resource.data.status == 'playing'
      && resource.data.players.white == null
      && request.resource.data.players.black == resource.data.players.black
      && validPlayer(request.resource.data.players.white)
      && request.resource.data.players.white.uid == request.auth.uid
      && request.resource.data.players.white.uid != resource.data.players.black.uid
      && request.resource.data.board == resource.data.board
      && request.resource.data.currentPlayer == resource.data.currentPlayer
      && request.resource.data.status == resource.data.status
      && request.resource.data.winner == resource.data.winner
      && request.resource.data.moveHistory == resource.data.moveHistory
      && request.resource.data.lastMove == resource.data.lastMove;
  }

  function validPlayerUpdate() {
    return isPlayer(resource.data)
      && request.resource.data.players.black == resource.data.players.black
      && request.resource.data.players.white == resource.data.players.white;
  }
}
